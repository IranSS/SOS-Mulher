<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".telas.LoginActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <!--   Header    -->
        <LinearLayout
            android:id="@+id/header_title"
            android:layout_marginTop="50dp"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:orientation="horizontal"
            android:gravity="center_horizontal">
            <ImageView
                android:id="@+id/img_title"
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:src="@mipmap/logo_sos_button_view" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="35dp"
                android:orientation="vertical"
                android:gravity="center"
                >
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bem vinda ao"
                    android:textSize="25dp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S.O.S Mulher"
                    android:textSize="20dp"
                    android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Acesse sua conta para continuar"
            android:layout_gravity="center_horizontal"
            android:textStyle="bold"
            android:textSize="20dp"/>
        <!--    Body    -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintTop_toBottomOf="@id/header_title"
            android:gravity="center_horizontal">
        <!--     campos para preencher       -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="120dp">
                <EditText
                    android:id="@+id/campo_email"
                    android:layout_width="359dp"
                    android:layout_height="48dp"
                    android:hint="Digite seu email"
                    android:textColorHint="@color/light_blue"
                    android:background="@drawable/borda"
                    android:inputType="textImeMultiLine"
                    android:autofillHints="emailAddress"/>
                <EditText
                    android:id="@+id/campo_senha"
                    android:layout_width="359dp"
                    android:layout_height="48dp"
                    android:hint="Digite sua senha"
                    android:textColorHint="@color/light_blue"
                    android:background="@drawable/borda"
                    android:layout_marginTop="20dp"
                    android:inputType="textImeMultiLine|textPassword"
                    android:autofillHints="password" />
                <TextView
                    android:id="@+id/alterar_senha_redirect"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/underlined_text"
                    android:layout_gravity="end"
                    />
                <Button
                    android:id="@+id/Button_entrar"
                    android:layout_width="130dp"
                    android:layout_height="48dp"
                    android:backgroundTint="@color/roxo"
                    android:text="Entrar"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="20dp"
                    app:cornerRadius="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OU"
                    android:textStyle="bold"
                    android:textColor="@color/light_gray"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"/>
                <Button
                    android:id="@+id/Button_cadastro"
                    android:layout_width="130dp"
                    android:layout_height="48dp"
                    android:backgroundTint="@color/light_gray"
                    android:text="Cadastre-se"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    app:cornerRadius="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>




</androidx.constraintlayout.widget.ConstraintLayout>