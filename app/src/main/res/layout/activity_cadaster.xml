<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:layout_marginTop="50dp">

            <ImageButton
                android:id="@+id/Button_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/arrow_back_"
                android:backgroundTint="@color/gray"
                android:layout_alignParentStart="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cadastro"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_centerInParent="true"/>
        </RelativeLayout>

        <!-- LINHA -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/roxo"
            android:layout_marginBottom="20dp"/>

        <!-- FORM -->
        <EditText
            android:id="@+id/inputText_nome"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/bg_input"
            android:hint="Nome"
            android:textColorHint="@color/light_blue"/>

        <EditText
            android:id="@+id/inputText_cpf"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="CPF"
            android:inputType="number"
            android:textColorHint="@color/light_blue"/>

        <EditText
            android:id="@+id/inputText_telefone"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="Telefone"
            android:inputType="phone"
            android:textColorHint="@color/light_blue"/>

        <EditText
            android:id="@+id/inputText_email"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="Email"
            android:inputType="textEmailAddress"
            android:textColorHint="@color/light_blue"/>

        <EditText
            android:id="@+id/inputText_senha"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="Senha"
            android:inputType="textPassword"
            android:textColorHint="@color/light_blue"/>

        <EditText
            android:id="@+id/inputText_confirme_senha"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="Repita sua senha"
            android:inputType="textPassword"
            android:textColorHint="@color/light_blue"/>

        <!-- BOTÃO -->
        <Button
            android:id="@+id/Button_cadastro"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="20dp"
            android:text="Cadastrar"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/roxo"
            app:cornerRadius="14dp"
            android:elevation="8dp"/>

    </LinearLayout>

</ScrollView>