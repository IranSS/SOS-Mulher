<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".telas.CadasterActivity">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <!--  Header  -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintBottom_toTopOf="@+id/body"
            android:layout_marginTop="30dp">
            <ImageButton
                android:id="@+id/Button_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/arrow_back_"
                android:backgroundTint="@color/black"
                android:layout_gravity="start|center_horizontal"
                android:layout_marginLeft="20dp"
                android:layout_marginBottom="5dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cadastro"
                android:textStyle="bold"
                android:textSize="25dp"
                android:layout_gravity="center"
                android:layout_marginBottom="5dp"/>
            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="@color/roxo"
                android:layout_gravity="end|bottom"/>
        </FrameLayout>
        <!--  Body  -->
        <LinearLayout
            android:id="@+id/body"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="center_vertical">
                <EditText
                    android:id="@+id/inputText_nome"
                    android:layout_width="359dp"
                    android:layout_height="48dp"
                    android:background="@drawable/borda"
                    android:hint="Nome"
                    android:textColorHint="@color/light_blue"
                    android:inputType="textImeMultiLine"
                    android:layout_gravity="center_horizontal"/>
                <EditText
                    android:id="@+id/inputText_cpf"
                    android:layout_width="359dp"
                    android:layout_height="48dp"
                    android:background="@drawable/borda"
                    android:hint="CPF"
                    android:textColorHint="@color/light_blue"
                    android:inputType="textImeMultiLine|numberDecimal"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"/>
                <EditText
                    android:id="@+id/inputText_telefone"
                    android:layout_width="359dp"
                    android:layout_height="48dp"
                    android:background="@drawable/borda"
                    android:hint="Telefone"
                    android:textColorHint="@color/light_blue"
                    android:inputType="textImeMultiLine|phone"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"/>
                <EditText
                    android:id="@+id/inputText_email"
                    android:layout_width="359dp"
                    android:layout_height="48dp"
                    android:background="@drawable/borda"
                    android:hint="Email"
                    android:textColorHint="@color/light_blue"
                    android:inputType="textImeMultiLine|text"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"/>
                <EditText
                    android:id="@+id/inputText_senha"
                    android:layout_width="359dp"
                    android:layout_height="48dp"
                    android:background="@drawable/borda"
                    android:hint="Senha"
                    android:textColorHint="@color/light_blue"
                    android:inputType="textImeMultiLine|textPassword"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"/>
                <EditText
                    android:id="@+id/inputText_confirme_senha"
                    android:layout_width="359dp"
                    android:layout_height="48dp"
                    android:background="@drawable/borda"
                    android:hint="Repita sua senha"
                    android:textColorHint="@color/light_blue"
                    android:inputType="textImeMultiLine|textPassword"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"/>
                <Button
                    android:id="@+id/Button_cadastro"
                    android:layout_width="120dp"
                    android:layout_height="48dp"
                    android:backgroundTint="@color/roxo"
                    android:text="cadastrar"
                    android:layout_gravity="center"
                    android:layout_marginTop="20dp"
                    app:cornerRadius="8dp"/>
            </LinearLayout>
        </LinearLayout>


    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>