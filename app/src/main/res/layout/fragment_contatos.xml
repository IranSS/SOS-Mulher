<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="15dp"
        android:layout_marginTop="30dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Adicionar contato de emergência"
            android:textStyle="bold"
            android:textSize="20sp"
            android:gravity="center"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/roxo"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"/>

        <!-- FORM -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nome do contato"
            android:layout_marginTop="8dp"/>

        <EditText
            android:id="@+id/definir_nome_contato"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/bg_input"
            android:hint="Digite o nome"
            android:textColorHint="@color/light_blue"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Email"
            android:layout_marginTop="12dp"/>

        <EditText
            android:id="@+id/definir_email_contato"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/bg_input"
            android:hint="Digite o e-mail"
            android:inputType="textEmailAddress"
            android:textColorHint="@color/light_blue"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Relação"
            android:layout_marginTop="12dp"/>

        <Spinner
            android:id="@+id/selecionar_relacao"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/bg_input"/>

        <!-- CHECKBOX -->
        <CheckBox
            android:id="@+id/definir_envio_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enviar minha localização em emergência"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/roxo"
            android:layout_gravity="center"/>

        <!-- BOTÃO -->
        <Button
            android:id="@+id/definir_contato"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:text="Adicionar contato"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/roxo"
            android:elevation="8dp"
            app:cornerRadius="14dp"/>


        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/roxo"
                android:padding="12dp">
                <!-- LISTA -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contatos de emergência"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:textSize="18sp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_contatos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>